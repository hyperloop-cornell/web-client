# Development environment configuration

# API Base URL for REST endpoints
# Leave unset by default. The app auto-uses http://localhost:8080 on localhost.
# Set this only when explicitly targeting a non-default backend during development.
# VITE_API_BASE_URL=http://localhost:8080

# Optional: Explicit WebSocket URL (if not set, derives from API_BASE_URL)
# VITE_WS_URL=ws://localhost:8080/ws/client
