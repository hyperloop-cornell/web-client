# Environment Configuration Examples

# ============================================================================
# DEVELOPMENT - Local backend (default)
# ============================================================================
# No need to set anything! The app defaults to http://localhost:8080
# Just run: npm run dev

# Optional: Override HMR (Hot Module Replacement) settings
# Only needed if accessing dev server from a different host
# VITE_HMR_HOST=localhost
# VITE_HMR_PROTOCOL=ws
# VITE_HMR_PORT=5173

# ============================================================================
# PRODUCTION - Remote backend
# ============================================================================
# Set this to deploy to production
# VITE_API_BASE_URL=https://gui.cornellhyperloop.com

# Optional: Explicit WebSocket URL
# VITE_WS_URL=wss://gui.cornellhyperloop.com/ws/client

# ============================================================================
# PRODUCTION WITH HMR - For testing production code locally
# ============================================================================
# Point dev server HMR to production domain for testing
# VITE_HMR_HOST=gui.cornellhyperloop.com
# VITE_HMR_PROTOCOL=wss
# VITE_HMR_PORT=443
# VITE_API_BASE_URL=https://gui.cornellhyperloop.com
